# ---------------------------------------------------------------------------
# Environment variable template — copy to .env and fill in real values
# ---------------------------------------------------------------------------

# --- LLM / Embedding provider (OpenRouter) ---
# Get your key at: https://openrouter.ai
OPENROUTER_API_KEY=your_openrouter_api_key_here

# --- Reranking provider ---
# Get your Cohere key at: https://cohere.com
COHERE_API_KEY=your_cohere_api_key_here

# --- PostgreSQL (Metadata Store) ---
POSTGRES_USER=raguser
POSTGRES_PASSWORD=ragpassword
POSTGRES_DB=ragdb

# --- MinIO (Object Storage — only needed for local Docker dev) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123

# --- Frontend CORS origin ---
FRONTEND_ORIGIN=http://localhost:3000

# --- Configuration directory ---
CONFIG_DIR=/app/config

# --- Qdrant (optional: use Qdrant Cloud instead of local Docker) ---
# Leave blank to use local Docker Qdrant
# QDRANT_URL=https://your-cluster.qdrant.io
# QDRANT_API_KEY=your_qdrant_cloud_api_key

# --- MinIO disable flag (set to true for HF Spaces deployment) ---
# DISABLE_MINIO=true
